###  http://example.org#obligation-content-share-treatment-plan2
ex:obligation-content-share-treatment-plan2 rdf:type owl:NamedIndividual ,
                                                     gc:TemporalAction ;
                                            gc:actionContent ex:action-content-share-treatment-plan2 ;
                                            gc:duration "P3DT0H0M"^^xsd:duration ;
                                            gc:numericDuration 259200000 .


###  http://example.org#obligation-share-treatment-plan1
ex:obligation-share-treatment-plan1 rdf:type owl:NamedIndividual ,
                                             gc:Obligation ;
                                    gc:activationCondition ex:alice-waltz-lab-result-2026-01-08-11-00-00 ;
                                    gc:obligationContent ex:obligation-content-share-treatment-plan1 .


###  http://example.org#obligation-share-treatment-plan2
ex:obligation-share-treatment-plan2 rdf:type owl:NamedIndividual ,
                                             gc:Obligation ;
                                    gc:activationCondition ex:anais-dupot-lab-result-2026-01-08-11-00-00 ;
                                    gc:obligationContent ex:obligation-content-share-treatment-plan2 .


###  http://www.wu.ac.at/2026/obligation-core-model#elapse
gc:elapse rdf:type owl:NamedIndividual ,
                   gc:Event ;
          gc:atTime "2026-01-11T12:30:00"^^xsd:dateTime ;
          gc:numericAtTime 1768134600000 .


###  http://www.wu.ac.at/2026/obligation-core-model#share
gc:share rdf:type owl:NamedIndividual ,
                  gc:Action .


