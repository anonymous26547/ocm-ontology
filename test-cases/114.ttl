                                              gc:atTime "2026-01-08T11:00:00"^^xsd:dateTime ;
                                              gc:numericAtTime 1767870000000 .


###  http://example.org#alice-waltz-lab-test-2026-01-07-10-30-00
ex:alice-waltz-lab-test-2026-01-07-10-30-00 rdf:type owl:NamedIndividual ,
                                                     hc:LabTest ;
                                            owl:differentFrom ex:anais-dupot-lab-result-2026-01-08-11-00-00 ,
                                                              ex:anais-dupot-lab-test-2026-01-08-10-30-00 ,
                                                              gc:elapse ;
                                            gc:atTime "2026-01-07T10:30:00"^^xsd:dateTime ;
                                            gc:numericAtTime 1767781800000 ;
                                            hc:hasLabResult ex:alice-waltz-lab-result-2026-01-08-11-00-00 ;
                                            hc:hasPatient ex:alice-waltz .


###  http://example.org#alice-waltz-treatment-plan-2026-01-08-11-11-00
ex:alice-waltz-treatment-plan-2026-01-08-11-11-00 rdf:type owl:NamedIndividual ,
                                                           hc:TreatmentPlan ;
                                                  hc:isBasedOnLabResult ex:alice-waltz-lab-result-2026-01-08-11-00-00 .


###  http://example.org#anais-dupot
ex:anais-dupot rdf:type owl:NamedIndividual ,
