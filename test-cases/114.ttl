                                              gc:numericAtTime 1767870000000 .


###  http://example.org#anais-dupot-lab-test-2026-01-08-10-30-00
ex:anais-dupot-lab-test-2026-01-08-10-30-00 rdf:type owl:NamedIndividual ,
                                                     hc:LabTest ;
                                            owl:differentFrom gc:elapse ;
                                            gc:atTime "2026-01-08T10:30:00"^^xsd:dateTime ;
                                            gc:numericAtTime 1767868200000 ;
                                            hc:hasLabResult ex:anais-dupot-lab-result-2026-01-08-11-00-00 ;
                                            hc:hasPatient ex:anais-dupot .


