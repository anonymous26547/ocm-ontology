###  http://example.org#action-content-share-treatment-plan1
ex:action-content-share-treatment-plan1 rdf:type owl:NamedIndividual ,
                                                 gc:RegulatedAction ;
                                        owl:differentFrom ex:action-content-share-treatment-plan2 ,
                                                          ex:alice-waltz-lab-result-2026-01-08-11-00-00 ,
                                                          ex:alice-waltz-lab-test-2026-01-07-10-30-00 ,
                                                          ex:anais-dupot-lab-result-2026-01-08-11-00-00 ,
                                                          ex:anais-dupot-lab-test-2026-01-08-10-30-00 ,
                                                          gc:elapse ;
                                        gc:action gc:share ;
                                        gc:receiver ex:alice-waltz ;
                                        gc:resource ex:alice-waltz-treatment-plan-2026-01-08-11-11-00 ;
                                        gc:sender ex:angelika-smith ;
                                        gc:atTime "2026-01-08T11:11:00"^^xsd:dateTime ;
                                        gc:numericAtTime 1767870660000 .


###  http://example.org#action-content-share-treatment-plan2
ex:action-content-share-treatment-plan2 rdf:type owl:NamedIndividual ,
                                                 gc:RegulatedAction ,
                                                 gem:NotKOnTimeExecutedAction ;
                                        gc:action gc:share ;
                                        gc:receiver ex:anais-dupot ;
                                        gc:resource ex:anais-dupot-treatment-plan-2026-01-08 ;
                                        gc:sender ex:angelika-smith .


###  http://example.org#alice-waltz
